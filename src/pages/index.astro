---
import BaseLayout from "../layouts/BaseLayout.astro";
import PlaceItem from "../components/PlaceItem.astro";
import { getCollection } from "astro:content";

const titlePage = "Pasea por Los Tuxtlas";
const allPlaces = await getCollection("places");
---

<BaseLayout titlePage={titlePage}>
  <ul>
    {
      allPlaces.map((place: any) => (
        <PlaceItem
          pageRef={`./${place.id}`}
          name={place.data.name}
          hero={place.data.hero}
        />
      ))
    }
  </ul>
</BaseLayout>
