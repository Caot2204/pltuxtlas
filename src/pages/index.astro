---
import BaseLayout from "../layouts/BaseLayout.astro";
import PlacesList from "../components/PlacesList.astro";
import PlaceSugestion from "../components/PlaceSugestion";
import { getCollection } from "astro:content";

const titlePage = "Pasea por Los Tuxtlas";
const allPlaces = await getCollection("places");
const initialPlace = allPlaces[Math.floor(Math.random() * allPlaces.length)];
---

<BaseLayout titlePage={titlePage}>
  <PlaceSugestion places={allPlaces} initialPlace={initialPlace} client:load />
  <PlacesList places={allPlaces} />  
</BaseLayout>