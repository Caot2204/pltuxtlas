---
import BaseLayout from "./BaseLayout.astro";
import Carrousel from "../components/Carrousel";
import { Image } from "astro:assets";
import { YouTube } from "@astro-community/astro-embed-youtube";

const { frontmatter } = Astro.props;
const carouselImages =
  frontmatter.images?.map((image: any) =>
    typeof image === "string" ? image : image?.src || image,
  ) ?? [];
---

<BaseLayout titlePage={frontmatter.name}>
  <div class=`place-container ${frontmatter.category}`>
    <div class="hero-data">
      <h1 class="hero-name">{frontmatter.name}</h1>
      <Image
        class="hero-place"
        src={frontmatter.hero}
        alt=`Imagen de ${frontmatter.name}`
      />
    </div>
    <slot />
    <h2>Conoce más de <em>{frontmatter.name}</em></h2>
    <div class="carrousel-div">
      <Carrousel
        imagenes={carouselImages}
        placeName={frontmatter.name}
        client:visible
      />
    </div>
    <section class="ytvideos-section">
      {
        frontmatter.youtubeIds &&
          frontmatter.youtubeIds.map((videoId: string) => (
            <YouTube class="youtube-video" id={videoId} />
          ))
      }
    </section>
  </div>
</BaseLayout>

<style>
  .place-container {
    padding: 0px 150px;
    padding-bottom: 8px;
    background-repeat: repeat-y;
    background-size: contain;
  }

  .place-container > * {
    margin-bottom: 20px;
  }

  .turistico {
    background-image: url("../assets/fondo-turistico.webp");
  }

  .playa {
    background-image: url("../assets/fondo-playa.webp");
  }

  .rio {
    background-image: url("../assets/fondo-rio.webp");
  }

  .hero-data {
    position: relative;
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    height: 85vh;
    overflow: hidden;
  }

  .hero-name {
    position: absolute;
    top: 24px;
    left: 24px;
    z-index: 2;
  }

  .hero-place {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .carrousel-div {
    display: flex;
    justify-content: center;
  }

  .ytvideos-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
  }

  .youtube-video {
    width: min(100%, 800px);
    max-width: 100%;
    border-radius: 10px;
  }
</style>
